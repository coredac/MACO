# ============================================================
# Ignore most intermediate files and caches
__pycache__/
*.log
*.tmp
algorithm/ex*

# ============================================================
# Secrets and local IDE/CLI config
.env
.env.*
.claude/
# ============================================================
# Ignore the entire tool directory, but keep test_process_candidates.py
tool/*
!tool/.gitkeep
!tool/test_process_candidates.py

# ============================================================
# Ignore the entire verilog_tool directory, but keep arch2dc.bash and generate_verilog.py
verilog_tool/*
!verilog_tool/.gitkeep
!verilog_tool/arch2dc.bash
!verilog_tool/generate_verilog.py

# ============================================================
# Ignore the entire results directory, only keep the empty directory
results/*
!results/.gitkeep

# ============================================================
# Ignore specified JSON files in baseline directory
baseline/qwen_domain_augmented_fft.json
baseline/qwen_domain_augmented_gemm.json
baseline/qwen_few_shot_examples_gemm.json
baseline/qwen_domain_augmented_conv.json
baseline/qwen_domain_augmented_fir.json
baseline/qwen_few_shot_examples_fir.json
